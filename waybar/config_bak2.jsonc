{
  "height": 30,
  "spacing": 4,
  "include": [
    "~/.config/waybar/waybar-quicklinks.jsonc",
    "~/.config/waybar/modules.jsonc"
  ],
  "modules-left": [
    "custom/appmenu",
    "group/quicklinks",
    "hyprland/window"
  ],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    // "mpris",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "keyboard-state",
    "battery",
    "clock",
    "tray",
    "custom/exit"
  ]
}
